{% if product.metafields.custom.fabric_cost_per_metre %}
  <div
    class="gbi-cushion-calculator bg-light p-23"
    style="padding: 20px; background: #f8f9fa; border-radius: 8px; margin-bottom: 20px;"
  >
    {% comment %} Metafield for Fabric Cost {% endcomment %}
    <input
      type="hidden"
      id="gbi-cushion-meta-metre-cost"
      value="{{ product.metafields.custom.fabric_cost_per_metre | default: 0 }}"
    >

    <div
      class="price_option_section"
      style="padding-top: 5px;"
    >
      <button
        type="button"
        id="gbi-cushion-calculate-btn"
        class="button button--primary"
        style="background: #000; color: #fff; padding: 12px 20px; border: none; cursor: pointer; font-weight: bold; border-radius: 4px; width: 100%;"
      >
        Calculate Price
      </button>

      <div class="second_option_section" style="margin-top: 15px; text-align: center;">
        <div class="price price--large">
          <span id="gbi-cushion-display-price" style="font-size: 24px; font-weight: bold; color: #333;">₹0.00</span>
        </div>
      </div>
    </div>

    <script src="{{ 'cushion-calculator.js' | asset_url }}" defer></script>
  </div>
{% endif %}

{% schema %}
{
  "name": "GBI Cushion Calculator",
  "target": "section",
  "templates": ["product"],
  "settings": []
}
{% endschema %}
